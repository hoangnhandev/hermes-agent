# Google Ads API Configuration
# All IDs are digits only, NO dashes. Copy to google-ads.env and fill real values.
GOOGLE_ADS_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_USE_PROTO_PLUS=True  # lib v17+ requires (proto-plus message style)
GOOGLE_ADS_API_VERSION=v21  # match installed lib

# The CHILD account that holds the campaigns (queried by monitor + deployed to).
GOOGLE_ADS_CUSTOMER_ID=1234567890

# MCC manager account ID. REQUIRED only if your token is an MCC manager account;
# otherwise leave commented out. If set, this is the manager; CUSTOMER_ID above
# is the child under it. (Setting both equal defeats the M2 fix — don't.)
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# Landing page real users land on after clicking an ad. MUST be a real URL for
# live spend (deploy blocks example.com unless --mock). No trailing slash.
GOOGLE_ADS_FINAL_URL=https://your-vinfast-dealer-site.com/vf3

# Conversion Tracking (create the conversion action in Google Ads UI first)
GOOGLE_ADS_CONVERSION_ACTION_ID=1234567890

# Google Cloud Project
GOOGLE_CLOUD_PROJECT_ID=hermes-ads-copilot

# Budget Guardrail — account monthly spend cap in VND (deploy refuses to exceed).
MONTHLY_BUDGET=6000000
# Account billing currency (drives VND→micros for the Google Ads API).
# VND = default. Set USD ONLY if your Google Ads account bills in USD.
ACCOUNT_CURRENCY=VND

# Cloudflare Workers (for D1 sync). HERMES_SYNC_SECRET must match Workers secret.
WORKERS_API_URL=https://ads-copilot.withly.org/api/sync
HERMES_SYNC_SECRET=change_me_to_random_string

# Telegram — TWO channels (optional; if both unset, creator still writes pending
# approvals — read the uuid from stdout). Tokens are bot tokens from @BotFather.
#
# REPORT/LEAD channel → daily report + lead notifications (broadcast audience).
TELEGRAM_BOT_TOKEN=123456:ABC-report-bot-token           # e.g. Rem-chan (reports bot)
TELEGRAM_CHAT_ID=-1001234567890                           # e.g. Vinfast ADS Notify group
#
# APPROVAL channel → ad-copy approval requests + deploy results (interactive:
# needs the user to approve/reject). Use the GATEWAY bot + the user's DM chat
# id so approvals land in the chat where the user talks to the agent.
TELEGRAM_APPROVAL_TOKEN=123456:ABC-gateway-bot-token     # e.g. Violet-chan (gateway bot)
TELEGRAM_APPROVAL_CHAT_ID=6097430138                      # user DM with the gateway bot
# (Approval falls back to the REPORT channel if TELEGRAM_APPROVAL_* are unset.)
