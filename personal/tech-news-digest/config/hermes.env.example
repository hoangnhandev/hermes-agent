# Hermes Agent secrets — TEMPLATE (fill real values, NEVER commit real ones)
# Lives at ~/.hermes/hermes.env on the host, chmod 600, owner = HERMES_UID (1000).
# Loaded into the gateway container via compose env_file (compose.hermes.local.yml).

# --- z.ai / GLM model provider (Coding Plan) ---
# Get key at https://z.ai. Coding Plan uses the /api/coding/paas/v4 endpoint.
GLM_API_KEY=<your-glm-key>

# --- Telegram gateway ---
TELEGRAM_BOT_TOKEN=<your-bot-token>
# TELEGRAM_ALLOWED_USERS=   # leave blank to use pairing instead

# --- Container timezone (for local-time cron) ---
TZ=Asia/Ho_Chi_Minh

# --- tech-news-digest skill credentials ---
# NOTE: TAVILY_API_KEY and GITHUB_TOKEN are in Hermes' provider-credential blocklist
# and get stripped from skill subprocesses. Use the RENAMED names below, and apply
# the matching rename in the skill scripts (see docs/skill-env-rename.md).
TWITTERAPI_IO_KEY=<twitterapi.io-key>          # Twitter/X KOL monitoring
TND_TAVILY_KEY=<tavily-key>                    # web search (renamed from TAVILY_API_KEY)
TND_GITHUB_TOKEN=<github-pat>                  # GitHub rate-limit boost (renamed from GITHUB_TOKEN)
# Optional (not configured by default):
# X_BEARER_TOKEN=
# BRAVE_API_KEY=
# REDDIT_CLIENT_ID=            # needs Reddit OAuth app (2024 policy)
# REDDIT_CLIENT_SECRET=
